{
  "name": "claude-obsidian",
  "version": "0.0.1",
  "private": true,
  "engines": {
    "node": ">=20"
  },
  "scripts": {
    "prepare": "husky",
    "format": "dprint fmt && markdownlint-cli2 --fix \"**/*.md\"",
    "lint": "dprint check && markdownlint-cli2 \"**/*.md\""
  },
  "devDependencies": {
    "dprint": "^0.54",
    "husky": "^9.1",
    "lint-staged": "^15.5",
    "markdownlint-cli2": "^0.18"
  },
  "lint-staged": {
    "*.md": ["dprint fmt", "markdownlint-cli2 --fix"]
  }
}
