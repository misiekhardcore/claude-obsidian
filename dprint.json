{
  "$schema": "https://dprint.dev/schemas/v0.json",
  "markdown": {
    "lineWidth": 10000,
    "textWrap": "never"
  },
  "includes": ["**/*.md"],
  "excludes": [
    ".raw/**",
    ".claude/**",
    ".worktrees/**",
    ".git/**",
    "node_modules/**",
    "_attachments/**",
    "AGENTS.md",
    "tests/fixtures/**"
  ],
  "plugins": ["https://plugins.dprint.dev/markdown-0.21.1.wasm"]
}
